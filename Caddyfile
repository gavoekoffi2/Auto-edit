{$BACKEND_DOMAIN:localhost} {
    encode gzip zstd

    # Limite de taille du body. DOIT être >= MAX_UPLOAD_SIZE_MB du backend,
    # sinon Caddy coupe l'upload en plein milieu avec un 413 (c'est ce qui
    # faisait "s'arrêter en chemin" les vidéos de téléphone > 2,1 Go).
    # Aligné à 5,2 Go par défaut, surchargeable via MAX_UPLOAD_BODY.
    request_body {
        max_size {$MAX_UPLOAD_BODY:5200MB}
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Strict-Transport-Security "max-age=31536000"
    }

    # Backend API. Keep /api/... intact because FastAPI mounts /api and /api/v1.
    reverse_proxy /api* backend:8000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        # Streaming immédiat dans les deux sens: upload poussé au backend au fur
        # et à mesure (pas de bufferisation complète), download/preview servi
        # sans attendre tout le fichier (Range/206 OK).
        flush_interval -1
        transport http {
            read_timeout 3600s
            write_timeout 3600s
            dial_timeout 30s
        }
    }

    # Optional: if this domain is opened directly, serve the built frontend too.
    reverse_proxy frontend:80
}
