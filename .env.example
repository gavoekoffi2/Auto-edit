# Database
DATABASE_URL=postgresql+asyncpg://autoedit:autoedit@postgres:5432/autoedit
DATABASE_URL_SYNC=postgresql://autoedit:autoedit@postgres:5432/autoedit

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (must be at least 32 characters)
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_FREE=300
MAX_VIDEO_DURATION_PRO=1800
MAX_VIDEOS_PER_MONTH_FREE=2

# FedaPay
FEDAPAY_SECRET_KEY=your-fedapay-secret-key
FEDAPAY_PUBLIC_KEY=your-fedapay-public-key
FEDAPAY_ENV=sandbox

# Whisper
WHISPER_MODEL=base

# Frontend
VITE_API_URL=http://localhost/api
