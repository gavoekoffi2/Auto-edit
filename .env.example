# =============================================================================
# AutoEdit — variables d'environnement
#
# Copier ce fichier en `.env` à la racine et remplir les valeurs.
# JAMAIS de secrets réels dans le repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Environnement (development | staging | production)
# - production active le fail-closed du rate-limiter et exige SECRET_KEY défini.
# -----------------------------------------------------------------------------
APP_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://autoedit:autoedit@postgres:5432/autoedit
DATABASE_URL_SYNC=postgresql://autoedit:autoedit@postgres:5432/autoedit
# Compose-only:
POSTGRES_USER=autoedit
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=autoedit

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# JWT — REQUIS en staging/production. Générer:  openssl rand -hex 32
# -----------------------------------------------------------------------------
SECRET_KEY=replace-me-with-output-of-openssl-rand-hex-32-aaaaaaaaaa
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS (origines autorisées séparées par des virgules) + URL publique
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost
PUBLIC_APP_URL=http://localhost
FRONTEND_ORIGIN=https://your-site.netlify.app
# Domaine public du backend en production. Exemple: srv1305401.hstgr.cloud ou api.autoedit.app
BACKEND_DOMAIN=localhost
# Email Let's Encrypt pour Caddy (renouvellement HTTPS automatique)
TLS_EMAIL=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_FREE=300
MAX_VIDEO_DURATION_PRO=1800
MAX_VIDEOS_PER_MONTH_FREE=2

# -----------------------------------------------------------------------------
# FedaPay (paiement Mobile Money + cartes)
# - FEDAPAY_SECRET_KEY est REQUIS en production sinon le webhook est rejeté.
# -----------------------------------------------------------------------------
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_ENV=sandbox

# -----------------------------------------------------------------------------
# Whisper (transcription locale)
# -----------------------------------------------------------------------------
WHISPER_MODEL=base
WHISPER_LANGUAGE=
WHISPER_INITIAL_PROMPT=

# -----------------------------------------------------------------------------
# Email transactionnel (signup / reset password / job done)
# Provider: console (dev only) | smtp | sendgrid
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=console
EMAIL_FROM=AutoEdit <noreply@autoedit.app>
# SMTP (utilisé si EMAIL_PROVIDER=smtp)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
# SendGrid (utilisé si EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# -----------------------------------------------------------------------------
# Observabilité (Sentry) — optionnel mais recommandé en prod
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Workers Celery
# -----------------------------------------------------------------------------
CELERY_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Frontend (build-time)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost/api
# En production Netlify, mettre exactement: https://VOTRE_BACKEND_DOMAIN/api
# Exemple: https://srv1305401.hstgr.cloud/api

# =============================================================================
# PIPELINE V2 — B-roll IA & renderers (ne sont utilisées que si activées)
# =============================================================================

# Version de pipeline par défaut: "v1" (existant, stable) ou "v2" (IA B-roll).
PIPELINE_VERSION=v1

# Génération d'images IA (B-roll) via OpenRouter
IMAGE_GENERATION_PROVIDER=openrouter
IMAGE_GENERATION_MODEL=google/gemini-2.5-flash-image
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://autoedit.app
OPENROUTER_X_TITLE=AutoEdit

# Style B-roll par défaut
BROLL_STYLE=african_business_premium
BROLL_DEFAULT_ASPECT_RATIO=9:16
BROLL_MAX_CUES_PER_VIDEO=12
BROLL_MIN_SEGMENT_DURATION=2.5
BROLL_MAX_SEGMENT_DURATION=8.0

# Renderer (overlays animés) — ffmpeg | hyperframes | remotion
VIDEO_RENDERER=hyperframes

# Feature flags produit
ENABLE_AI_BROLL=true
# Scènes motion design illustrées (dessins animés qui illustrent le discours).
# Fonctionne même sans OPENROUTER_API_KEY (dessins procéduraux trait-par-trait).
ENABLE_MOTION_DESIGN=true

# --- Budget API images (économie) -------------------------------------------
# Cap d'images B-roll générées par vidéo + cadence (secondes par image).
MAX_BROLL_IMAGES=8
SECONDS_PER_BROLL=9.0
SHORTS_SECONDS_PER_BROLL=6.0
# Nombre max de scènes motion design illustrées par l'IA (les autres utilisent
# les dessins procéduraux gratuits). 0 = jamais d'illustration IA.
MOTION_AI_ILLUSTRATIONS_MAX=3
# Précision des images: un modèle texte bon marché réécrit chaque extrait parlé
# en scène visuelle littérale avant la génération (fallback heuristique).
PROMPT_REFINER_ENABLED=1
PROMPT_REFINER_MODEL=google/gemini-2.5-flash-lite

# --- Découpe intelligente -----------------------------------------------------
# Supprime faux départs, phrases répétées, marqueurs "je reprends", bégaiements.
ENGINE_REMOVE_RETAKES=1
ENABLE_DYNAMIC_CAPTIONS=true
ENABLE_SFX=true
ENABLE_MUSIC=true
